/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/msproteomics Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // -----------------------------------------------------------------------
    // Resource labels
    // -----------------------------------------------------------------------
    withLabel:process_tiny {
        cpus   = { 1                   }
        memory = { 1.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_very_low {
        cpus   = { 2     * task.attempt }
        memory = { 4.GB  * task.attempt }
        time   = { 3.h   * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 4     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 6.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 8     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 32     * task.attempt }
        memory = { 240.GB * task.attempt }
        time   = { 16.h   * task.attempt }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withLabel:process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }

    // -----------------------------------------------------------------------
    // DIA-NN workflow resource overrides
    // DIA-NN processes require higher resources than the global defaults.
    // scratch = false prevents Nextflow from staging files to local scratch.
    // -----------------------------------------------------------------------
    withName: '.*DIANN.*' {
        scratch = false
    }
    withName: '.*DIANN_INSILICOLIBRARYGENERATION' {
        cpus   = { 8     * 4 ** (task.attempt - 1) }
        memory = { 60.GB * 4 ** (task.attempt - 1) }
        time   = { 8.h   * task.attempt            }
    }
    withName: '.*DIANN_PRELIMINARYANALYSIS' {
        cpus   = { 8     * 4 ** (task.attempt - 1) }
        memory = { 60.GB * 4 ** (task.attempt - 1) }
        time   = { 8.h   * task.attempt            }
    }
    withName: '.*DIANN_ASSEMBLEEMPIRICALLIBRARY' {
        cpus   = { 16     * 4 ** (task.attempt - 1) }
        memory = { 123.GB * 4 ** (task.attempt - 1) }
        time   = { 8.h    * task.attempt             }
    }
    withName: '.*DIANN_INDIVIDUALANALYSIS' {
        cpus   = { 16     * 4 ** (task.attempt - 1) }
        memory = { 123.GB * 4 ** (task.attempt - 1) }
        time   = { 8.h    * task.attempt             }
    }
    withName: '.*DIANN_FINALQUANTIFICATION' {
        cpus   = { 16     * 4 ** (task.attempt - 1) }
        memory = { 123.GB * 4 ** (task.attempt - 1) }
        time   = { 8.h    * task.attempt             }
    }
}
