/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ======================================================================
    // DIA workflow publishDir configs
    // ======================================================================

    withName: '.*:THERMORAWFILEPARSER' {
        ext.args = '--format 2'
        publishDir = [
            path: { "${params.outdir}/mzml" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*DIANN_INSILICOLIBRARYGENERATION' {
        publishDir = [
            path: { "${params.outdir}/diann/insilico_library" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*DIANN_PRELIMINARYANALYSIS' {
        publishDir = [
            path: { "${params.outdir}/diann/preliminary_analysis" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*DIANN_ASSEMBLEEMPIRICALLIBRARY' {
        publishDir = [
            path: { "${params.outdir}/diann/empirical_library" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*DIANN_INDIVIDUALANALYSIS' {
        publishDir = [
            path: { "${params.outdir}/diann/individual_analysis" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*DIANN_FINALQUANTIFICATION' {
        publishDir = [
            path: { "${params.outdir}/diann/diann_quantification" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'QUANTMSUTILS_MZMLSTATISTICS' {
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/quantmsutils/mzml_statistics" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'QUANTMSUTILS_DIANN2MZTAB' {
        publishDir = [
            path: { "${params.outdir}/quantmsutils/mztab" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'QUANTMSUTILS_DIANNCFG' {
        publishDir = [
            path: { "${params.outdir}/quantmsutils/config" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ======================================================================
    // DIA-NN workflow process configs (--mode diann)
    // ======================================================================

    // QUANTMSUTILS_GENERATECFG - Configuration generation
    withName: 'QUANTMSUTILS_DIANNCFG' {
        ext.args = ''
    }

    // DIANN_INSILICOLIBRARYGENERATION - In-silico library generation
    // What makes this "In-Silico Library Generation":
    //   - Input: FASTA file + enzyme/modification config (from meta.config)
    //   - Key flags: --fasta-search --predictor --gen-spec-lib --met-excision --rt-profiling
    //   - Output: *.predicted.speclib (predicted spectral library from sequences)
    //   - No MS data input required at this stage
    withName: 'DIANN_INSILICOLIBRARYGENERATION' {
        ext.args = {[
            meta.config ?: '',
            params.diann_min_pr_mz ? "--min-pr-mz ${params.diann_min_pr_mz}" : '',
            params.diann_max_pr_mz ? "--max-pr-mz ${params.diann_max_pr_mz}" : '',
            params.diann_min_fr_mz ? "--min-fr-mz ${params.diann_min_fr_mz}" : '',
            params.diann_max_fr_mz ? "--max-fr-mz ${params.diann_max_fr_mz}" : '',
            params.allowed_missed_cleavages != null ? "--missed-cleavages ${params.allowed_missed_cleavages}" : '',
            params.min_peptide_length ? "--min-pep-len ${params.min_peptide_length}" : '',
            params.max_peptide_length ? "--max-pep-len ${params.max_peptide_length}" : '',
            params.min_precursor_charge ? "--min-pr-charge ${params.min_precursor_charge}" : '',
            params.max_precursor_charge ? "--max-pr-charge ${params.max_precursor_charge}" : '',
            params.max_mods != null ? "--var-mods ${params.max_mods}" : '',
            params.diann_library_mass_acc ? "--mass-acc ${params.diann_library_mass_acc}" : '',
            params.diann_library_ms1_acc ? "--mass-acc-ms1 ${params.diann_library_ms1_acc}" : '',
            params.diann_debug ? "--verbose ${params.diann_debug}" : '',
            "--fasta-search",
            "--predictor",
            "--gen-spec-lib",
            "--rt-profiling",
            params.met_excision ? "--met-excision" : '',
            params.additional_insilico_args ?: ''
        ].findAll { it != '' }.join(' ').trim()}
    }

    // DIANN_PRELIMINARYANALYSIS - Preliminary analysis
    // What makes this "Preliminary Analysis":
    //   - Input: Individual MS files + predicted spectral library
    //   - Key flags: --quick-mass-acc (fast mass accuracy estimation), performance mode flags
    //   - NO --individual-mass-acc or --individual-windows (determined later from logs)
    //   - Output: *.quant files (preliminary quantification for each file)
    //   - Purpose: Generate data to automatically determine optimal mass accuracy and scan window settings
    // Note: mass_acc and scan_window are NOT set during preliminary analysis in quantms
    // when using automatic modes - they're determined from the preliminary results
    withName: 'DIANN_PRELIMINARYANALYSIS' {
        ext.args = {[
            params.diann_debug ? "--verbose ${params.diann_debug}" : '',
            params.diann_quick_mass_acc ? "--quick-mass-acc" : '',
            params.diann_performance_mode ? "--min-corr 2 --corr-diff 1 --time-corr-only" : '',
            meta.mass_acc_ms2 ? "--mass-acc ${meta.mass_acc_ms2}" : '',
            meta.mass_acc_ms1 ? "--mass-acc-ms1 ${meta.mass_acc_ms1}" : '',
            meta.scan_window ? "--window ${meta.scan_window}" : '',
            params.diann_additional_analysis_args ?: ''
        ].findAll { it != '' }.join(' ').trim()}
    }

    // DIANN_ASSEMBLEEMPIRICALLIBRARY - Empirical library assembly
    // What makes this "Empirical Library Assembly":
    //   - Input: All MS files + predicted library + preliminary *.quant files
    //   - Key flags: --rt-profiling --gen-spec-lib
    //   - Uses --individual-mass-acc and --individual-windows (if automatic mode enabled)
    //   - Output: empirical_library.* (refined library based on actual data)
    //   - Purpose: Build experiment-specific library using preliminary results to improve identifications
    withName: 'DIANN_ASSEMBLEEMPIRICALLIBRARY' {
        ext.prefix = 'empirical_library'
        ext.args = {[
            params.diann_debug ? "--verbose ${params.diann_debug}" : '',
            "--rt-profiling",
            "--gen-spec-lib",
            "--matrices",
            params.protein_level_fdr_cutoff != null ? "--qvalue ${params.protein_level_fdr_cutoff}" : '',
            meta.mass_acc_ms2 && meta.mass_acc_ms1 ? "--mass-acc ${meta.mass_acc_ms2} --mass-acc-ms1 ${meta.mass_acc_ms1}" : "--individual-mass-acc",
            meta.scan_window ? "--window ${meta.scan_window}" : "--individual-windows",
            params.diann_additional_analysis_args ?: ''
        ].findAll { it != '' }.join(' ').trim()}
    }

    // DIANN_INDIVIDUALANALYSIS - Individual analysis
    // What makes this "Individual Analysis":
    //   - Input: Individual MS file + empirical library + FASTA
    //   - Key flags: --no-ifs-removal --no-main-report (suppress full reports, only generate .quant)
    //   - Uses refined mass accuracy settings from empirical library log (meta.mass_acc_ms1, meta.mass_acc_ms2, meta.scan_window)
    //   - Output: *.quant files (individual quantification for each file with refined library)
    //   - Purpose: Re-analyze each file individually with optimal settings before final aggregation
    withName: 'DIANN_INDIVIDUALANALYSIS' {
        ext.args = {
            [
                params.diann_debug ? "--verbose ${params.diann_debug}" : '',
                "--no-ifs-removal",
                "--no-main-report",
                "--relaxed-prot-inf",
                meta.pg_level ? "--pg-level ${meta.pg_level}" : '',
                "--mass-acc ${meta.mass_acc_ms2}",
                "--mass-acc-ms1 ${meta.mass_acc_ms1}",
                "--window ${meta.scan_window}",
                params.diann_additional_analysis_args ?: ''
            ].findAll { it != '' }.join(' ').trim()
        }
    }

    // DIANN_FINALQUANTIFICATION - Final quantification
    // What makes this "Final Quantification":
    //   - Input: All MS file names (basenames only) + empirical library + all individual *.quant files + FASTA
    //   - Key flags: --matrices (generate quantification matrices)
    //   - Outputs: diann_report.tsv, *.pr_matrix.tsv, *.pg_matrix.tsv (precursor and protein group quantification)
    //   - NOTE: The quantms FINAL_QUANTIFICATION module computes scan_window/individual-windows
    //     but does NOT pass it to the command. We match this behavior exactly.
    //   - Purpose: Aggregate all individual analyses into final cross-run normalized quantification
    withName: 'DIANN_FINALQUANTIFICATION' {
        ext.prefix = 'diann_report'
        ext.args = {[
            params.diann_debug ? "--verbose ${params.diann_debug}" : '',
            "--relaxed-prot-inf",
            params.diann_pg_level != null ? "--pg-level ${params.diann_pg_level}" : '',
            params.species_genes ? "--species-genes" : '',
            "--matrices",
            params.protein_level_fdr_cutoff != null ? "--qvalue ${params.protein_level_fdr_cutoff}" : '',
            params.diann_report_decoys ? "--report-decoys" : '',
            params.diann_export_xic ? "--xic" : '',
            params.diann_additional_analysis_args ?: ''
        ].findAll { it != '' }.join(' ').trim()}
    }

    withName: 'QUANTMSUTILS_DIANN2MZTAB' {
        ext.args = {
            [
                params.max_precursor_charge ? "--charge ${params.max_precursor_charge}" : '',
                params.allowed_missed_cleavages != null ? "--missed_cleavages ${params.allowed_missed_cleavages}" : '',
                params.protein_level_fdr_cutoff != null ? "--qvalue_threshold ${params.protein_level_fdr_cutoff}" : '',
                params.enable_diann_mztab ? "--enable_diann2mztab" : '',
                meta.dia_params ? "--dia_params \"${meta.dia_params}\"" : ''
            ].findAll { it != '' }.join(' ').trim()
        }
    }

    withName: 'SAMPLESHEET_CHECK' {
        ext.skip_ms_validation = params.skip_ms_validation
        ext.skip_factor_validation = params.skip_factor_validation
        ext.skip_experimental_design_validation = params.skip_experimental_design_validation
        ext.use_ols_cache_only = params.use_ols_cache_only
        publishDir = [
            path: { "${params.outdir}/sdrf" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MSSTATS_LFQ' {
        ext.ref_condition = params.ref_condition
        ext.contrasts = params.contrasts
        ext.remove_one_feat_prot = params.msstats_remove_one_feat_prot
        ext.removeFewMeasurements = params.msstatslfq_removeFewMeasurements
        ext.feature_subset_protein = params.msstatslfq_feature_subset_protein
        ext.quant_summary_method = params.msstatslfq_quant_summary_method
        ext.msstats_threshold = params.msstats_threshold
    }

    withName: 'MZML_STATISTICS' {
        ext.id_only = params.id_only
        ext.mzml_features = params.mzml_features
    }

    withName: 'OPENMS_PEAK_PICKER' {
        ext.peakpicking_inmemory = params.peakpicking_inmemory
        ext.peakpicking_ms_levels = params.peakpicking_ms_levels
        ext.pp_debug = params.pp_debug
    }

    withName: 'PMULTIQC' {
        ext.enable_pmultiqc = params.enable_pmultiqc
        ext.export_mztab = params.export_mztab
        ext.skip_table_plots = params.skip_table_plots
        ext.pmultiqc_idxml_skip = params.pmultiqc_idxml_skip
        ext.contaminant_string = params.contaminant_string
        ext.quantification_method = params.quantification_method
    }

    withName: 'SDRF_PARSING' {
        ext.convert_dotd = params.convert_dotd
    }

    withName: 'GENERATE_SDRF' {
        publishDir = [
            path: { "${params.outdir}/sdrf" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'GENERATE_SDRF_FROM_SAMPLESHEET' {
        publishDir = [
            path: { "${params.outdir}/sdrf" },
            mode: params.publish_dir_mode
        ]
    }

    // ======================================================================
    // FragPipe workflow process configs
    // ======================================================================

    //
    // THERMORAWFILEPARSER for FragPipe workflows
    //
    withName: '.*FRAGPIPE.*:THERMORAWFILEPARSER.*' {
        ext.args = '--format 2'
        publishDir = [
            path: { "${params.outdir}/mzml/${meta.id}" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // THERMORAWFILEPARSER for TMT Label Check workflows
    //
    withName: '.*TMT_LABELCHECK.*:THERMORAWFILEPARSER' {
        ext.args = '--format 2'
    }

    //
    // TMT_LABELCHECK_ANALYZE - Per-sample labeling efficiency analysis
    //
    withName: '.*TMT_LABELCHECK.*:TMT_LABELCHECK_ANALYZE' {
        ext.pass_threshold = 0.95
        ext.warn_threshold = 0.85
        ext.prob_threshold = 0.95
    }

    //
    // TMT_LABELCHECK_ANALYZE_IONQUANT - Combined labeling efficiency analysis
    //
    withName: '.*TMT_LABELCHECK.*:TMT_LABELCHECK_ANALYZE_IONQUANT' {
        ext.pass_threshold = 0.95
        ext.warn_threshold = 0.85
    }

    //
    // PHILOSOPHER_DATABASE - FASTA preparation with decoys/contaminants
    //
    withName: '.*FRAGPIPE.*:PHILOSOPHER_DATABASE' {
        ext.args = ''
        publishDir = [
            path: { "${params.outdir}/database" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MSFRAGGER - Database search
    //
    withName: '.*FRAGPIPE.*:.*MSFRAGGER.*' {
        cpus   = { 32 * task.attempt }
        memory = { 240.GB * task.attempt }
        ext.java_xmx = 230
        publishDir = [
            path: { "${params.outdir}/msfragger" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MSFRAGGER_INDEX - Pepindex prebuilding
    //
    withName: '.*FRAGPIPE.*:MSFRAGGER_INDEX' {
        cpus   = { 16 * task.attempt }
        memory = { 120.GB * task.attempt }
        publishDir = [
            path: { "${params.outdir}/msfragger_index" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MSFRAGGER_CALIBRATE - Mass calibration + parameter optimization
    //
    withName: '.*FRAGPIPE.*:MSFRAGGER_CALIBRATE' {
        cpus   = { 32 * task.attempt }
        memory = { 240.GB * task.attempt }
        ext.java_xmx = 230
        publishDir = [
            path: { "${params.outdir}/msfragger_calibrate" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // SPLIT_FASTA - Split FASTA for parallel search
    //
    withName: '.*FRAGPIPE.*:SPLIT_FASTA' {
        cpus   = 1
        memory = { 4.GB * task.attempt }
        publishDir = [
            path: { "${params.outdir}/split_fasta" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MERGE_SPLIT_SEARCH - Merge pepXML + PIN across database chunks
    //
    withName: '.*FRAGPIPE.*:MERGE_SPLIT_SEARCH' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        publishDir = [
            path: { "${params.outdir}/merge_split_search" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MSBOOSTER - AI-based rescoring
    //
    withName: '.*FRAGPIPE.*:MSBOOSTER' {
        publishDir = [
            path: { "${params.outdir}/msbooster" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // CRYSTALC - Chimeric artifact removal
    //
    withName: '.*FRAGPIPE.*:CRYSTALC' {
        publishDir = [
            path: { "${params.outdir}/crystalc" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PTMPROPHET - PTM site localization
    //
    withName: '.*FRAGPIPE.*:PTMPROPHET' {
        publishDir = [
            path: { "${params.outdir}/ptmprophet" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PEPTIDEPROPHET - Peptide-level validation
    //
    withName: '.*FRAGPIPE.*:PEPTIDEPROPHET' {
        publishDir = [
            path: { "${params.outdir}/peptideprophet" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PERCOLATOR - PSM-level FDR control
    //
    withName: '.*FRAGPIPE.*:PERCOLATOR' {
        ext.args = ''
        ext.min_prob = '0.5'
        ext.decoy_tag = 'rev_'
        publishDir = [
            path: { "${params.outdir}/percolator" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PROTEINPROPHET - Protein inference
    //
    withName: '.*FRAGPIPE.*:PROTEINPROPHET' {
        publishDir = [
            path: { "${params.outdir}/proteinprophet" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PHILOSOPHER_FILTER - FDR filtering and report
    //
    withName: '.*FRAGPIPE.*:PHILOSOPHER_FILTER' {
        ext.decoy_tag = 'rev_'
        publishDir = [
            path: { "${params.outdir}/philosopher" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // IONQUANT - Label-free quantification
    //
    withName: '.*FRAGPIPE.*:IONQUANT' {
        cpus   = { 48 * task.attempt }
        memory = { 370.GB * task.attempt }
        stageInMode = 'copy'
        publishDir = [
            path: { "${params.outdir}/ionquant" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // IONQUANT_MS1 - TMT MS1 precursor intensity quantification
    //
    withName: '.*FRAGPIPE.*:IONQUANT_MS1' {
        stageInMode = 'copy'
        publishDir = [
            path: { "${params.outdir}/ionquant_ms1" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // IONQUANT_ISOBARIC - TMT reporter ion quantification
    //
    withName: '.*FRAGPIPE.*:IONQUANT_ISOBARIC' {
        stageInMode = 'copy'
        publishDir = [
            path: { "${params.outdir}/ionquant_isobaric" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // TMTINTEGRATOR - TMT quantification and normalization
    //
    withName: '.*FRAGPIPE.*:TMTINTEGRATOR' {
        publishDir = [
            path: { "${params.outdir}/tmtintegrator" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // SPECLIBGEN - Spectral library generation
    //
    withName: '.*FRAGPIPE.*:SPECLIBGEN' {
        publishDir = [
            path: { "${params.outdir}/speclib" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // PTMSHEPHERD - PTM analysis
    //
    withName: '.*FRAGPIPE.*:PTMSHEPHERD' {
        publishDir = [
            path: { "${params.outdir}/ptmshepherd" },
            mode: params.publish_dir_mode
        ]
    }


    //
    // FRAGPIPE_HEADLESS - All-in-one FragPipe execution
    //
    withName: '.*FRAGPIPE.*:FRAGPIPE_HEADLESS' {
        cpus   = { 90 * task.attempt }
        memory = { 760.GB * task.attempt }
        scratch = true
        publishDir = [
            path: { "${params.outdir}/fragpipe" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // TMT Label Check analysis
    //
    withName: '.*:TMT_LABELCHECK_ANALYZE' {
        publishDir = [
            path: { "${params.outdir}/qc" },
            mode: params.publish_dir_mode
        ]
    }

    withName: '.*:TMT_LABELCHECK_ANALYZE_IONQUANT' {
        publishDir = [
            path: { "${params.outdir}/qc_combined" },
            mode: params.publish_dir_mode
        ]
    }

    //
    // MultiQC
    //
    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
