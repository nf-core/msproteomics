// nf-test for CrystalC module
nextflow_process {

    name "Test Process CRYSTALC"
    script "../main.nf"
    process "CRYSTALC"

    tag "modules"
    tag "modules_nfcore"
    tag "crystalc"

    test("crystalc - stub") {
        options "-stub"
        tag "stub"

        when {
            process {
                """
                def pepxml_file = file("\${workDir}/test.pep.xml")
                pepxml_file.text = "<?xml version='1.0'?><msms_pipeline_analysis></msms_pipeline_analysis>"
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "mock"
                def config_file = file("\${workDir}/crystalc.params")
                config_file.text = "precursor_charge = 1 6\\nisotope_number = 3\\nprecursor_mass = 20\\nprecursor_isolation_window = 0.7\\ncorrect_isotope_error = false"
                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">PROT1\\nPEPTIDEK"

                input[0] = channel.of([
                    [ id: 'test_crystalc' ],
                    pepxml_file,
                    mzml_file,
                    config_file
                ])
                input[1] = fasta_file
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out.results_dir, process.out.pepxml_filtered, process.out.versions_crystalc, process.out.versions_fragpipe).match() }
            )
        }
    }

    test("crystalc - integration with test data") {
        tag "integration"

        when {
            process {
                """
                // Use real MSFragger pepXML output from test-datasets (must match mzML scan numbers)
                def pepxml_file = file("\${params.pipelines_testdata_base_path}/module_inputs/crystalc_test.pepXML", checkIfExists: true)
                // mzML is a large binary spectra file — keep remote
                def mzml_file = file("\${params.pipelines_testdata_base_path}/module_inputs/crystalc_test.mzML", checkIfExists: true)
                def fasta_file = file("\${params.pipelines_testdata_base_path}/databases/erwinia_carotovora.fasta", checkIfExists: true)
                // Create CrystalC params inline
                // database_name must point to the FASTA filename — staged files live in the work dir's current directory
                def config_file = file("\${workDir}/crystalc.params")
                config_file.text = "precursor_charge = 1 6\\n" +
                    "isotope_number = 3\\n" +
                    "precursor_mass = 20\\n" +
                    "precursor_isolation_window = 0.7\\n" +
                    "correct_isotope_error = false\\n" +
                    "database_name = erwinia_carotovora.fasta"

                input[0] = channel.of([
                    [ id: 'crystalc_test' ],
                    pepxml_file,
                    mzml_file,
                    config_file
                ])
                input[1] = fasta_file
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                // Only snapshot pepxml_filtered and versions (crystalc.log varies between runs)
                { assert snapshot(process.out.pepxml_filtered, process.out.versions_crystalc, process.out.versions_fragpipe).match() }
            )
        }
    }
}
