nextflow_process {

    name "Test Process DECOMPRESS"
    script "../main.nf"
    process "DECOMPRESS"

    tag "modules"
    tag "modules_nfcore"
    tag "decompress"

    test("decompress - stub") {
        tag "stub"
        options "-stub"

        when {
            process {
                """
                def compressed_file = file("\${workDir}/sample.d.tar.gz")
                compressed_file.text = "mock"

                input[0] = channel.of([
                    [ id: 'test', mzml_id: 'test_sample' ],
                    compressed_file
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out.decompressed_files, process.out.log).match() }
            )
        }
    }
}
