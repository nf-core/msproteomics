nextflow_process {

    name "Test Process FRAGPIPE_HEADLESS"
    script "../main.nf"
    process "FRAGPIPE_HEADLESS"

    tag "modules"
    tag "modules_nfcore"
    tag "fragpipe_headless"

    test("fragpipe_headless - stub") {
        tag "stub"
        options "-stub"

        when {
            process {
                """
                def raw_file = file("\${workDir}/sample.mzML")
                raw_file.text = "mock"
                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">sp|P00001|TEST\\nMKTEST"
                def workflow_file = file("\${workDir}/test.workflow")
                workflow_file.text = "mock"

                input[0] = raw_file
                input[1] = fasta_file
                input[2] = workflow_file
                input[3] = "sample.mzML\\texperiment1\\t1\\tDDA"
                input[4] = ""
                input[5] = ""
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.all_results,
                    process.out.combined_protein,
                    process.out.combined_peptide,
                    process.out.combined_ion
                ).match() }
            )
        }
    }
}
