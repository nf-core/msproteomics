nextflow_process {

    name "Test Process FREEQUANT"
    script "../main.nf"
    process "FREEQUANT"

    tag "modules"
    tag "modules_nfcore"
    tag "freequant"

    test("freequant - stub") {
        options "-stub"
        tag "stub"

        when {
            process {
                """
                def results_dir = file("\${workDir}/results")
                results_dir.mkdirs()
                def psm_file = file("\${workDir}/results/psm.tsv")
                psm_file.text = "peptide\\tprotein\\nPEPTIDEK\\tPROT1"
                def mzml_dir = file("\${workDir}/spectra")
                mzml_dir.mkdirs()
                def mzml_file = file("\${workDir}/spectra/test.mzML")
                mzml_file.text = "mock"
                // FreeQuant CLI config
                def config_cli = "--ptw 0.4 --tol 10"

                input[0] = channel.of([[ id: 'test_freequant' ], results_dir, mzml_dir, config_cli])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.results_dir,
                    process.out.ions,
                    process.out.versions_philosopher,
                    process.out.versions_fragpipe
                ).match() }
            )
        }
    }

    // Freequant requires a complete Philosopher workspace (.meta/psm.bin)
    // which can only be generated by the full chain:
    // MSFragger → PeptideProphet → ProteinProphet → Philosopher Filter → FreeQuant
    // Module-level integration is tested via fragpipe_quant subworkflow tests.
    // See: subworkflows/local/fragpipe_quant/tests/main.nf.test
}
