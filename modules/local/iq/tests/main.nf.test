nextflow_process {

    name "Test Process IQ"
    script "../main.nf"
    process "IQ"

    tag "modules"
    tag "modules_nfcore"
    tag "iq"

    test("iq - stub") {
        tag "stub"
        options "-stub"

        when {
            process {
                """
                def report_file = file("\${workDir}/diann_report.tsv")
                report_file.text = "mock"

                input[0] = report_file
                input[1] = 0.01
                input[2] = 0.01
                input[3] = "CONT_"
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out.contaminants_removed_report, process.out.maxlfq).match() }
            )
        }
    }
}
