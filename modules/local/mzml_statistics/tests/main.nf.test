nextflow_process {

    name "Test Process MZML_STATISTICS"
    script "../main.nf"
    process "MZML_STATISTICS"

    tag "modules"
    tag "modules_nfcore"
    tag "mzml_statistics"

    test("mzml_statistics - stub") {
        tag "stub"
        options "-stub"

        when {
            process {
                """
                def mzml_file = file("\${workDir}/sample.mzML")
                mzml_file.text = "mock"

                input[0] = channel.of([
                    [ id: 'test', mzml_id: 'test_sample' ],
                    mzml_file
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.ms_statistics,
                    process.out.ms2_statistics,
                    process.out.feature_statistics,
                    process.out.log
                ).match() }
            )
        }
    }
}
