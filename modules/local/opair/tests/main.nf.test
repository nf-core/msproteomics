nextflow_process {

    name "Test Process OPAIR"
    script "../main.nf"
    process "OPAIR"

    tag "modules"
    tag "modules_nfcore"
    tag "opair"

    test("opair - stub") {
        options "-stub"
        tag "stub"

        when {
            process {
                """
                def psm_file = file("\${workDir}/psm.tsv")
                psm_file.text = "peptide\\tprotein\\nPEPTIDEK\\tPROT1"
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "mock"
                def glycan_db = file("\${workDir}/glycan_db.txt")
                glycan_db.text = "HexNAc(1)Hex(1)\\t365.1322"
                // O-Pair CLI config
                def config_cli = "-b 20 -c 20 -n 3 -z STY"

                input[0] = channel.of([
                    [ id: 'test_opair' ],
                    psm_file,
                    [ mzml_file ],
                    config_cli
                ])
                input[1] = glycan_db
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.results_dir,
                    process.out.results,
                    process.out.glycoforms,
                    process.out.versions_opair,
                    process.out.versions_fragpipe
                ).match() }
            )
        }
    }

    test("opair - integration with test data") {
        tag "integration"

        when {
            process {
                """
                // Create test input files inline
                def psm_file = file("\${workDir}/psm.tsv")
                psm_file.text = "Spectrum\\tSpectrum File\\tPeptide\\tModified Peptide\\tExtended Peptide\\tPrev AA\\tNext AA\\tPeptide Length\\tCharge\\tRetention\\tObserved Mass\\tCalibrated Observed Mass\\tObserved M/Z\\tCalibrated Observed M/Z\\tCalculated Peptide Mass\\tCalculated M/Z\\tDelta Mass\\tExpectation\\tHyperscore\\tNextscore\\tPeptideProphet Probability\\tNumber of Enzymatic Termini\\tNumber of Missed Cleavages\\tProtein Start\\tProtein End\\tIntensity\\tAssigned Modifications\\tObserved Modifications\\tPurity\\tIs Unique\\tProtein\\tProtein ID\\tEntry Name\\tGene\\tProtein Description\\tMapped Genes\\tMapped Proteins\\n" +
                    "tmt_erwinia_subset.00001.00001.2\\ttmt_erwinia_subset.mzML\\tPEPTIDEKTEST\\tPEPTIDEKM[147]TEST\\tR.PEPTIDEKTEST.A\\tR\\tA\\t12\\t2\\t30.01\\t1234.5678\\t1234.5679\\t618.2912\\t618.2912\\t1234.5678\\t618.2912\\t0.0001\\t0.0001\\t25.5\\t12.3\\t0.999\\t2\\t0\\t100\\t112\\t1500000\\t8M(15.9949)\\t8M(15.9949)\\t0.95\\tTRUE\\tsp|P12345|TEST_ECOLI\\tP12345\\tTEST_ECOLI\\tTEST\\tTest protein OS=Erwinia carotovora GN=test PE=1 SV=1\\tTEST\\tsp|P12345|TEST_ECOLI\\n" +
                    "tmt_erwinia_subset.00002.00002.3\\ttmt_erwinia_subset.mzML\\tANOTHERPEPTIDER\\tANOTHERPEPTIDER\\tK.ANOTHERPEPTIDER.L\\tK\\tL\\t15\\t3\\t35.01\\t1567.8901\\t1567.8902\\t523.6374\\t523.6374\\t1567.8901\\t523.6374\\t0.0001\\t0.00005\\t30.2\\t15.1\\t0.9995\\t2\\t0\\t200\\t215\\t2500000\\t\\t\\t0.98\\tTRUE\\tsp|P23456|PROT2_ECOLI\\tP23456\\tPROT2_ECOLI\\tPROT2\\tAnother test protein OS=Erwinia carotovora GN=prot2 PE=1 SV=1\\tPROT2\\tsp|P23456|PROT2_ECOLI"
                // mzML is a large binary file — keep remote
                def mzml_file = file("\${params.pipelines_testdata_base_path}/spectra/tmt_erwinia_subset.mzML", checkIfExists: true)
                // Create glycan database inline
                def glycan_db = file("\${workDir}/glycan_db.txt")
                glycan_db.text = "HexNAc(1)Hex(1)\\t365.1322\\n" +
                    "HexNAc(2)Hex(1)\\t568.2117\\n" +
                    "HexNAc(1)Hex(2)\\t527.1850\\n" +
                    "HexNAc(2)Hex(2)\\t730.2645\\n" +
                    "HexNAc(3)Hex(1)\\t771.2912\\n" +
                    "Fuc(1)HexNAc(1)Hex(1)\\t511.1901\\n" +
                    "NeuAc(1)\\t291.0954"
                def config_cli = "-b 20 -c 20 -n 3 -z STY"

                input[0] = channel.of([
                    [ id: 'opair_test' ],
                    psm_file,
                    [ mzml_file ],
                    config_cli
                ])
                input[1] = glycan_db
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.results_dir,
                    process.out.results,
                    process.out.glycoforms,
                    process.out.versions_opair,
                    process.out.versions_fragpipe
                ).match() }
            )
        }
    }
}
