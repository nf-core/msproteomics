nextflow_process {

    name "Test Process OPENMS_PEAK_PICKER"
    script "../main.nf"
    process "OPENMS_PEAK_PICKER"

    tag "modules"
    tag "modules_nfcore"
    tag "openms_peak_picker"

    test("openms_peak_picker - stub") {
        tag "stub"
        options "-stub"

        when {
            process {
                """
                def mzml_file = file("\${workDir}/sample.mzML")
                mzml_file.text = "mock"

                input[0] = channel.of([
                    [ id: 'test', mzml_id: 'test_sample' ],
                    mzml_file
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out.mzmls_picked, process.out.log, process.out.versions_openms).match() }
            )
        }
    }
}
