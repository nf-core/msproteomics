nextflow_process {

    name "Test Process PTMSHEPHERD"
    script "../main.nf"
    process "PTMSHEPHERD"

    tag "modules"
    tag "modules_nfcore"
    tag "ptmshepherd"

    test("ptmshepherd - stub") {
        options "-stub"
        tag "stub"

        when {
            process {
                """
                def psm_dir = file("\${workDir}/sample1")
                psm_dir.mkdirs()
                def psm_file = file("\${workDir}/sample1/psm.tsv")
                psm_file.text = "peptide\\tprotein\\nPEPTIDEK\\tPROT1"
                def protxml_file = file("\${workDir}/combined.prot.xml")
                protxml_file.text = "<?xml version='1.0'?><protein_summary></protein_summary>"
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "mock"
                def config_file = file("\${workDir}/ptms_input.config")
                config_file.text = "histo_bindivs = 5000\\nhisto_smoothbins = 2\\nprecursor_tol = 0.01\\nspectra_ppmtol = 20\\nlocalization_background = 4\\noutput_extended = false"

                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">sp|P00000|TEST_HUMAN Test protein\\nMKWVTFISLLLFSSAYSRGVFRRDTHKSEIAHR"

                input[0] = channel.of([
                    [ id: 'test_shepherd' ],
                    [ psm_dir ],
                    protxml_file,
                    [ mzml_file ],
                    config_file
                ])
                input[1] = channel.value(fasta_file)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.results_dir,
                    process.out.global_profile,
                    process.out.global_modsummary,
                    process.out.diagmine,
                    process.out.localization,
                    process.out.glycoprofile,
                    process.out.versions_ptmshepherd,
                    process.out.versions_fragpipe
                ).match() }
            )
        }
    }

    test("ptmshepherd - integration with test data") {
        tag "integration"

        when {
            process {
                """
                // Use real PSM data from test-datasets directly (PSMs reference
                // tmt_erwinia_subset as the spectrum file basename)
                def psm_dir = file("\${workDir}/sample1")
                psm_dir.mkdirs()
                def remote_psm = file("\${params.pipelines_testdata_base_path}/module_inputs/psm.tsv", checkIfExists: true)
                def psm_file = file("\${workDir}/sample1/psm.tsv")
                psm_file.text = remote_psm.text
                def protxml_file = file("\${workDir}/combined.prot.xml")
                protxml_file.text = "<?xml version='1.0'?><protein_summary></protein_summary>"
                def mzml_file = file("\${params.pipelines_testdata_base_path}/spectra/tmt_erwinia_subset.mzML", checkIfExists: true)
                def config_file = file("\${workDir}/ptms_input.config")
                config_file.text = "histo_bindivs = 5000\\n" +
                    "histo_smoothbins = 2\\n" +
                    "precursor_tol = 0.01\\n" +
                    "spectra_ppmtol = 20\\n" +
                    "localization_background = 4\\n" +
                    "output_extended = false\\n" +
                    "mass_offsets = 0\\n" +
                    "isotope_error = 0\\n" +
                    "precursor_mass_units = 0\\n" +
                    "run_glyco_mode = false\\n" +
                    "cap_y_ions = 0\\n" +
                    "oxonium_filtering = false\\n" +
                    "msfragger_massdiff_to_varmod = 0\\n" +
                    "annotation_tol = 0.01\\n" +
                    "peakpicking_promRatio = 0.3\\n" +
                    "peakpicking_width = 3.0"

                def fasta_file = file("\${params.pipelines_testdata_base_path}/databases/erwinia_carotovora.fasta", checkIfExists: true)

                input[0] = channel.of([
                    [ id: 'ptmshepherd_test' ],
                    [ psm_dir ],
                    protxml_file,
                    [ mzml_file ],
                    config_file
                ])
                input[1] = channel.value(fasta_file)
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                // results_dir contains non-deterministic log (timestamps, memory)
                { assert process.out.results_dir.size() > 0 },
                // global_profile and global_modsummary have non-deterministic floating-point
                // values (spectral similarity, localization) — verify existence and content
                { assert process.out.global_profile.size() == 1 },
                { assert process.out.global_modsummary.size() == 1 },
                { assert path(process.out.global_profile[0][1]).text.contains('peak_apex') },
                { assert path(process.out.global_modsummary[0][1]).text.contains('Modification') },
                { assert process.out.versions_ptmshepherd.size() == 1 },
                { assert process.out.versions_fragpipe.size() == 1 }
            )
        }
    }
}
