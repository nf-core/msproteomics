nextflow_process {

    name "Test Process SKYLINE"
    script "../main.nf"
    process "SKYLINE"

    tag "modules"
    tag "modules_nfcore"
    tag "skyline"

    test("skyline - stub") {
        options "-stub"
        tag "stub"

        when {
            process {
                """
                def results_dir = file("\${workDir}/results")
                results_dir.mkdirs()
                def psm_file = file("\${workDir}/results/psm.tsv")
                psm_file.text = "peptide\\tprotein\\nPEPTIDEK\\tPROT1"
                def speclib_file = file("\${workDir}/test.speclib")
                speclib_file.text = "mock"
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "mock"
                // Skyline path and CLI config
                def skyline_path = "/usr/bin/skyline"
                def config_cli = "--irt-standard Biognosys-11"

                input[0] = channel.of([
                    [ id: 'test_skyline' ],
                    results_dir,
                    [ mzml_file ],
                    speclib_file,
                    config_cli
                ])
                input[1] = skyline_path
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.results_dir,
                    process.out.skyline_document,
                    process.out.reports,
                    process.out.versions_skyline,
                    process.out.versions_fragpipe
                ).match() }
            )
        }
    }

    // Note: Full integration test requires Windows environment for Skyline
    // Skyline is primarily a Windows application with limited Linux support
}
