/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/msproteomics Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments
----------------------------------------------------------------------------------------
*/

// Nextflow plugins MUST be declared at the very top, before any module parsing
plugins {
    id 'nf-schema@2.5.1'
}

nextflow.enable.moduleBinaries = true

/*
========================================================================================
    PARAMETERS
========================================================================================
*/

params {
    // Workflow mode: 'diann' (DIA-NN) or 'fragpipe' (FragPipe-based DDA/TMT workflows)
    mode = null

    // TMT options (fragpipe only)
    tmt_mode = null              // 'labelcheck' or 'quant'
    tmt_type = null              // TMT plex type: TMT6, TMT10, TMT11, TMT16, TMT18, TMTPRO

    // Optional explicit config file override
    config_file = null

    // Input options
    input = null

    // Sample metadata (experiment-level, used for SDRF generation)
    organism = 'Homo sapiens'
    dissociation_method = 'HCD'
    local_input_type = 'mzML'
    id_only = false

    // Database options (shared)
    database = null

    // FDR thresholds (shared)
    protein_fdr = 0.01
    peptide_fdr = 0.01
    psm_fdr     = 0.01

    // -------------------------------------------------------------------------
    // DIA-NN parameters (--mode diann)
    // These control the DIA-NN analysis engine for DIA workflows.
    // -------------------------------------------------------------------------
    diann_speclib                = null
    diann_empirical_assembly_lib = null
    diann_empirical_assembly_log = null
    diann_debug             = 3
    diann_export_xic        = false
    diann_report_decoys     = false

    // DIA-NN search parameters
    enzyme                   = 'Trypsin/P'
    fixed_mods               = null
    variable_mods            = 'Oxidation (M)'
    max_mods                 = 3
    allowed_missed_cleavages = 1
    min_peptide_length       = 7
    max_peptide_length       = 30
    min_precursor_charge     = 1
    max_precursor_charge     = 4
    met_excision             = true

    // DIA-NN mass tolerance
    precursor_mass_tolerance      = 20
    precursor_mass_tolerance_unit = 'ppm'
    fragment_mass_tolerance       = 20
    fragment_mass_tolerance_unit  = 'ppm'

    // DIA-NN in-silico library generation
    diann_min_pr_mz          = 350
    diann_max_pr_mz          = 1050
    diann_min_fr_mz          = 200
    diann_max_fr_mz          = 1800
    diann_library_mass_acc   = 18
    diann_library_ms1_acc    = 5
    additional_insilico_args = null

    // DIA-NN analysis
    diann_scan_window              = 8
    diann_scan_window_automatic    = true
    diann_mass_acc_automatic       = true
    protein_level_fdr_cutoff = 0.01
    diann_pg_level                 = 2
    species_genes            = false
    diann_performance_mode         = false
    diann_quick_mass_acc           = false
    diann_random_preanalysis       = false
    diann_random_preanalysis_seed  = 42
    diann_empirical_assembly_ms_n  = 200

    // DIA-NN workflow control
    diann_skip_preliminary_analysis = false
    diann_additional_analysis_args  = ''

    // DIA-NN workflow metadata (used for SDRF generation)
    acquisition_method = 'dia'
    labelling_type     = 'label free sample'
    fragment_method    = 'HCD'
    is_phospho_data    = false

    // DIA-NN post-processing (IQ R package / MaxLFQ)
    diann_maxlfq_q            = 0.01
    diann_maxlfq_pgq          = 0.05
    contaminant_pattern = 'contaminant_'

    // -------------------------------------------------------------------------
    // FragPipe parameters (--mode fragpipe)
    // FragPipe tool parameters (MSFragger, IonQuant, etc.) are defined in
    // .workflow files, NOT here. These params control pipeline behavior only.
    // -------------------------------------------------------------------------
    fragpipe_workflow      = null      // Path to .workflow file (user must provide via --fragpipe_workflow)
    fragpipe_mode          = 'pipeline'
    philosopher_database   = null
    tmt_annotation         = null
    msfragger_num_slices   = 1
    decoy_tag              = 'rev_'

    // Test mode flag
    test_mode = false

    // SDRF validation options
    validate_ontologies = true
    skip_ms_validation = false
    skip_factor_validation = true
    skip_experimental_design_validation = false
    use_ols_cache_only = true

    // File preparation
    reindex_mzml = true
    convert_dotd = false
    openms_peakpicking = false
    peakpicking_inmemory = false
    peakpicking_ms_levels = null
    pp_debug = 0
    mzml_features = false

    // Decoy options
    add_decoys = false
    decoy_string = 'DECOY_'
    decoy_string_position = 'prefix'
    decoy_method = 'reverse'
    shuffle_max_attempts = 30
    shuffle_sequence_identity_threshold = 0.5

    // Reporting (PMULTIQC)
    enable_pmultiqc = true
    pmultiqc_idxml_skip = true
    contaminant_string = 'CONT'
    export_mztab = true
    enable_diann_mztab = false
    quantification_method = 'feature_intensity'
    skip_table_plots = false

    // MSstats general options
    enable_msstats = true
    msstats_remove_one_feat_prot = true
    ref_condition = null
    contrasts = 'pairwise'
    msstats_threshold = 0.05
    skip_post_msstats = false

    // MSstats LFQ options
    msstatslfq_removeFewMeasurements = true
    msstatslfq_feature_subset_protein = 'top3'
    msstatslfq_quant_summary_method = 'TMP'

    // References (iproteomes - UniProt reference proteomes)
    genome                     = null
    proteomes_base             = null
    proteomes_ignore           = true

    // MultiQC options
    multiqc_config             = null
    multiqc_title              = null
    multiqc_logo               = null
    max_multiqc_email_size     = '25.MB'
    multiqc_methods_description = null

    // Boilerplate options
    outdir                       = null
    publish_dir_mode             = 'copy'
    email                        = null
    email_on_fail                = null
    plaintext_email              = false
    monochrome_logs              = false
    hook_url                     = System.getenv('HOOK_URL')
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/'
    trace_report_suffix          = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

    // Config options
    config_profile_name        = null
    config_profile_description = null
    custom_config_version      = 'master'
    custom_config_base         = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_contact     = null
    config_profile_url         = null

    // Schema validation
    validate_params            = true
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm64 {
        process.arch            = 'arm64'
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gpu {
        docker.runOptions       = '-u $(id -u):$(id -g) --gpus all'
        apptainer.runOptions    = '--nv'
        singularity.runOptions  = '--nv'
    }
    aws {
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    test {
        params.test_mode  = true
        params.max_cpus   = 2
        params.max_memory = '6.GB'
        params.max_time   = '1.h'

        process {
            resourceLimits = [ cpus: 2, memory: 6.GB, time: 1.h ]
            cpus   = 2
            memory = '6.GB'
            time   = '1.h'
        }
    }
    test_dia     { includeConfig 'conf/tests/test_dia.config'     }
    test_dda_lfq { includeConfig 'conf/tests/test_dda_lfq.config' }
    test_tmt     { includeConfig 'conf/tests/test_tmt.config'     }
    test_tmtq    { includeConfig 'conf/tests/test_tmtq.config'    }
}

// Load nf-core custom profiles from different institutions
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Set default registry for container engines
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

// Load reference proteomes if required
includeConfig !params.proteomes_ignore ? 'conf/reference_proteomes.config' : 'conf/reference_proteomes_ignored.config'

// Export env vars to prevent local Python/R libraries from conflicting with containers
env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

// Set bash options
process.shell = [
    "bash",
    "-C",
    "-e",
    "-u",
    "-o",
    "pipefail"
]

// Disable process selector warnings by default
nextflow.enable.configProcessNamesValidation = false

process {
    // Resource limits
    resourceLimits = [ cpus: 96, memory: 760.GB, time: 72.h ]

    // Retry on errors (spot eviction, OOM, etc.)
    errorStrategy = "retry"
    maxRetries    = { task.exitStatus in ((130..145) + 104) ? 3 : 1 }
    maxErrors     = 5

    // FragPipe licensed tool agreement
    ext.agree_fragpipe_license_agreement = true

    // FragPipe tools directory (matches fragpipe/fragpipe:24.0 image layout)
    ext.fragpipe_tools_dir = '/fragpipe_bin/fragpipe-24.0/fragpipe-24.0/tools'
}

// Pipeline reporting
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_report_suffix}.html"
}

manifest {
    name            = 'nf-core/msproteomics'
    contributors    = [
        [
            name: 'Dongze He',
            affiliation: 'Altos Labs',
            email: 'dongzehe.zaza@gmail.com',
            github: 'DongzeHE',
            contribution: ['author'],
            orcid: ''
        ],
        [
            name: 'Fengchao Yu',
            affiliation: 'University of Michigan',
            email: 'yufe@fragmatics.com',
            github: 'fcyu',
            contribution: ['author'],
            orcid: ''
        ],
    ]
    homePage        = 'https://github.com/nf-core/msproteomics'
    description     = """Mass spectrometry proteomics preprocessing (DIA, DDA LFQ, TMT)"""
    mainScript      = 'main.nf'
    defaultBranch   = 'master'
    nextflowVersion = '!>=25.04.0'
    version         = '1.0.0dev'
    doi             = ''
}

validation {
    defaultIgnoreParams = ["genomes"]
    monochromeLogs = params.monochrome_logs
}

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'

