/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
        publishDir = List of maps with publish directory options
----------------------------------------------------------------------------------------
*/

process {

    //
    // Module-specific configuration for FRAGPIPE_WF subworkflow
    //

    withName: '.*FRAGPIPE_WF.*:PARSE_FRAGPIPE_WORKFLOW' {
        publishDir = [
            path: { "${params.outdir}/fragpipe/configs" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:PHILOSOPHER_DATABASE' {
        ext.args = '--reviewed --contam'
        publishDir = [
            path: { "${params.outdir}/fragpipe/database" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:THERMORAWFILEPARSER' {
        ext.args = '-f 2'  // Output mzML format
        publishDir = [
            path: { "${params.outdir}/fragpipe/mzml" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:MSFRAGGER' {
        // Default MSFragger args - can be overridden by workflow config
        ext.args = ''
        ext.calibrate_mass = '2'  // Auto-calibrate mass
        publishDir = [
            path: { "${params.outdir}/fragpipe/msfragger" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:MSBOOSTER' {
        ext.args = ''
        publishDir = [
            path: { "${params.outdir}/fragpipe/msbooster" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:PERCOLATOR' {
        ext.args = '--only-psms --no-terminate --post-processing-tdc'
        publishDir = [
            path: { "${params.outdir}/fragpipe/percolator" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:PROTEINPROPHET' {
        ext.args = '--maxppmdiff 2000000'
        publishDir = [
            path: { "${params.outdir}/fragpipe/proteinprophet" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:PHILOSOPHER_FILTER' {
        ext.args = ''
        publishDir = [
            path: { "${params.outdir}/fragpipe/filter/${task.tag}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:IONQUANT' {
        ext.args = '--mbr 1 --maxlfq 1 --requantify 1'
        publishDir = [
            path: { "${params.outdir}/fragpipe/ionquant" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*FRAGPIPE_WF.*:TMTINTEGRATOR' {
        ext.args = ''
        publishDir = [
            path: { "${params.outdir}/fragpipe/tmtintegrator" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

//
// Default params for the subworkflow
//
params {
    outdir = './results'
    publish_dir_mode = 'copy'
}
