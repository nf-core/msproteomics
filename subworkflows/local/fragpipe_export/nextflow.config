/*
 * Configuration for FRAGPIPE_EXPORT subworkflow
 *
 * Includes: SKYLINE, SAINTEXPRESS, FPOP, METAPROTEOMICS
 */

process {
    withName: 'SKYLINE' {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }

    withName: 'SAINTEXPRESS' {
        cpus   = { 2 * task.attempt }
        memory = { 8.GB * task.attempt }
        time   = { 1.h * task.attempt }
    }

    withName: 'FPOP' {
        cpus   = { 2 * task.attempt }
        memory = { 8.GB * task.attempt }
        time   = { 1.h * task.attempt }
    }

    withName: 'METAPROTEOMICS' {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }
}

params {
    outdir = 'results'
    publish_dir_mode = 'copy'
}
