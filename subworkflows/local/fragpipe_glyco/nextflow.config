/*
 * Configuration for FRAGPIPE_GLYCO subworkflow
 *
 * Includes: MBG, OPAIR
 */

process {
    withName: 'MBG' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }

    withName: 'OPAIR' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
}

params {
    outdir = 'results'
    publish_dir_mode = 'copy'
}
