/*
 * Test configuration for FRAGPIPE_HEADLESS_WF subworkflow tests
 */

process {
    cpus   = 2
    memory = 12.GB
    time   = 1.h
    resourceLimits = [ cpus: 2, memory: 12.GB, time: 1.h ]

    withName: 'THERMORAWFILEPARSER' {
        container = 'quay.io/biocontainers/thermorawfileparser:1.4.5--h05cac1d_1'
        ext.args = '-f 2'
    }

    // FRAGPIPE_HEADLESS inherits process.container (commercial FragPipe)
    // because it requires licensed tools (MSFragger, IonQuant, etc.)
}

params {
    outdir = 'results'
    publish_dir_mode = 'copy'
}
