/*
 * Configuration for FRAGPIPE_SEARCH subworkflow
 *
 * Includes: MSFRAGGER, MSBOOSTER, CRYSTALC
 */

process {
    withName: 'MSFRAGGER' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }

    withName: 'MSBOOSTER' {
        cpus   = { 4 * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 2.h * task.attempt }
    }

    withName: 'CRYSTALC' {
        cpus   = { 4 * task.attempt }
        memory = { 8.GB * task.attempt }
        time   = { 1.h * task.attempt }
    }
}

params {
    outdir = 'results'
    publish_dir_mode = 'copy'
}
