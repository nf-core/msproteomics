    test("fragpipe_search - stub with all tools") {
        options "-stub"
        tag "stub"

        when {
            workflow {
                """
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "<?xml version='1.0'?><mzML></mzML>"
                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">PROT1\\nPEPTIDEK"

                // Tool configs: all tools enabled
                def tool_configs = [
                    msfragger: [run: true, args: '--precursor_mass_tolerance 20'],
                    msbooster: [run: true, args: '--predictRT true'],
                    crystalc:  [run: true, args: '# Crystal-C params']
                ]

                input[0] = channel.of([[ id: 'test_search_all' ], mzml_file])
                input[1] = channel.value(fasta_file)
                input[2] = channel.value(groovy.json.JsonOutput.toJson(tool_configs))
                input[3] = []          // ch_fragger_params (CLI mode)
                input[4] = []          // ch_msbooster_params (CLI mode)
                input[5] = 1          // ch_num_slices (standard, no split)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.pepxml,
                    workflow.out.pin,
                    workflow.out.pin_rescored,
                    workflow.out.tsv,
                    workflow.out.results_dir,
                    workflow.out.uncalibrated_mzml
                ).match() }
            )
        }
    }

    test("fragpipe_search - stub with split database search (num_slices=2)") {
        options "-stub"
        tag "stub"

        when {
            workflow {
                """
                // Two mock mzML files to exercise M×N cartesian product (2 chunks × 2 samples)
                def mzml_file_1 = file("\${workDir}/sample_A.mzML")
                mzml_file_1.text = "<?xml version='1.0'?><mzML></mzML>"
                def mzml_file_2 = file("\${workDir}/sample_B.mzML")
                mzml_file_2.text = "<?xml version='1.0'?><mzML></mzML>"

                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">PROT1\\nPEPTIDEK\\n>PROT2\\nANOTHERK"

                // Fragger params file required by MSFRAGGER_CALIBRATE (stub copies it)
                def fragger_params = file("\${workDir}/fragger.params")
                fragger_params.text = "calibrate_mass = 2\\nnum_threads = 2\\nprecursor_mass_tolerance = 20"

                // Tool configs: only msfragger enabled (simplest split path)
                def tool_configs = [
                    msfragger: [run: true, args: '--precursor_mass_tolerance 20'],
                    msbooster: [run: false, args: ''],
                    crystalc:  [run: false, args: '']
                ]

                input[0] = channel.of(
                    [[ id: 'sample_A' ], mzml_file_1],
                    [[ id: 'sample_B' ], mzml_file_2]
                )
                input[1] = channel.value(fasta_file)
                input[2] = channel.value(groovy.json.JsonOutput.toJson(tool_configs))
                input[3] = channel.value(fragger_params)  // ch_fragger_params (needed for calibration)
                input[4] = []          // ch_msbooster_params (CLI mode)
                input[5] = 2          // ch_num_slices (split database search)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.pepxml,
                    workflow.out.pin,
                    workflow.out.pin_rescored,
                    workflow.out.tsv,
                    workflow.out.results_dir,
                    workflow.out.uncalibrated_mzml
                ).match() }
            )
        }
    }
}
