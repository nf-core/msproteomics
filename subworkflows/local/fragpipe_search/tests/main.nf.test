nextflow_workflow {

    name "Test Subworkflow FRAGPIPE_SEARCH"
    script "../main.nf"
    workflow "FRAGPIPE_SEARCH"
    config "./test.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "fragpipe_search"

    test("fragpipe_search - stub with msfragger only") {
        options "-stub"
        tag "stub"

        when {
            workflow {
                """
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "<?xml version='1.0'?><mzML></mzML>"
                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">PROT1\\nPEPTIDEK"

                // Tool configs: only msfragger enabled
                def tool_configs = [
                    msfragger: [run: true, args: '--precursor_mass_tolerance 20'],
                    msbooster: [run: false, args: ''],
                    crystalc:  [run: false, args: '']
                ]

                input[0] = channel.of([[ id: 'test_search' ], mzml_file])
                input[1] = channel.value(fasta_file)
                input[2] = channel.value(groovy.json.JsonOutput.toJson(tool_configs))
                input[3] = []          // ch_fragger_params (CLI mode)
                input[4] = []          // ch_msbooster_params (CLI mode)
                input[5] = 1          // ch_num_slices (standard, no split)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.pepxml,
                    workflow.out.pin,
                    workflow.out.pin_rescored,
                    workflow.out.tsv,
                    workflow.out.results_dir,
                    workflow.out.uncalibrated_mzml
                ).match() }
            )
        }
    }

    test("fragpipe_search - stub with msbooster") {
        options "-stub"
        tag "stub"

        when {
            workflow {
                """
                def mzml_file = file("\${workDir}/test.mzML")
                mzml_file.text = "<?xml version='1.0'?><mzML></mzML>"
                def fasta_file = file("\${workDir}/test.fasta")
                fasta_file.text = ">PROT1\\nPEPTIDEK"

                // Tool configs: msfragger + msbooster enabled
                def tool_configs = [
                    msfragger: [run: true, args: '--precursor_mass_tolerance 20'],
                    msbooster: [run: true, args: '--predictRT true'],
                    crystalc:  [run: false, args: '']
                ]

                input[0] = channel.of([[ id: 'test_search_boost' ], mzml_file])
                input[1] = channel.value(fasta_file)
                input[2] = channel.value(groovy.json.JsonOutput.toJson(tool_configs))
                input[3] = []          // ch_fragger_params (CLI mode)
                input[4] = []          // ch_msbooster_params (CLI mode)
                input[5] = 1          // ch_num_slices (standard, no split)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.pepxml,
                    workflow.out.pin,
                    workflow.out.pin_rescored,
                    workflow.out.tsv,
                    workflow.out.results_dir,
                    workflow.out.uncalibrated_mzml
                ).match() }
            )
        }
    }

