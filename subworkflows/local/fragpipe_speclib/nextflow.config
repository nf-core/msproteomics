/*
 * Configuration for FRAGPIPE_SPECLIB subworkflow
 *
 * Includes: SPECLIBGEN
 */

process {
    withName: 'SPECLIBGEN' {
        cpus   = { 8 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
}

params {
    outdir = 'results'
    publish_dir_mode = 'copy'
}
