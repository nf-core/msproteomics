nextflow_workflow {

    name "Test Subworkflow INPUT_CHECK"
    script "../main.nf"
    workflow "INPUT_CHECK"
    config "./test.config"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "input_check"

    test("input_check - stub") {
        tag "stub"
        options "-stub"

        when {
            workflow {
                """
                def sdrf_file = file("\${workDir}/test_sdrf.tsv")
                sdrf_file.text = "source name\\tcomment[data file]\\ntest\\ttest.raw"

                input[0] = sdrf_file
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out.ch_input_file, workflow.out.is_sdrf).match() }
            )
        }
    }
}
