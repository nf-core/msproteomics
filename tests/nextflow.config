/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// Test-specific parameters and resource overrides
params {
    modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/an-altosian/test-datasets/refs/heads/msproteomics'
}

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

// Cap resources for CI runners (GitHub Actions has 2 CPUs, 7GB RAM)
process.resourceLimits = [
    cpus: 2,
    memory: '6.GB',
    time: '6.h'
]
